NODE_ENV=development
PORT=3000

# Lokal Postgres for testing
DATABASE_URL=postgresql://sc_app:replace-with-password@localhost:5432/sc_dev

# Fil-lagring: local eller supabase
STORAGE_PROVIDER=local

# Kun nodvendig nar STORAGE_PROVIDER=supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_STORAGE_BUCKET=project-files

# Settes til en lang tilfeldig streng (minst 32 tegn)
SESSION_SECRET=replace-with-long-random-secret

# Sett en reell admin-bruker
ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@sorhaugconsulting.no
# Generer med: npm run hash:password -- "SterktPassord123!"
ADMIN_PASSWORD_HASH=replace-with-bcrypt-hash

# Settes til en annen lang tilfeldig streng (minst 32 tegn)
ASSET_SIGNING_SECRET=replace-with-another-long-random-secret
